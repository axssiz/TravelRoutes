    "route_structure": {
      "id": "number (timestamp)",
      "from": "string (город отправления)",
      "to": "string (город назначения)",
      "distance": "number (км)",
      "duration": "string (например: '17 часов')",
      "description": "string (описание маршрута)",
      "stops": [
        {
          "id": "string",
          "name": "string (название города)",
          "type": "string ('остановка')",
