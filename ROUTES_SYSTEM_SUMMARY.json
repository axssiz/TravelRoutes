{
  "routes_system": {
    "version": "1.0.0",
    "status": "✅ ГОТОВА К ИСПОЛЬЗОВАНИЮ",
    "components": [
      {
        "name": "RouteSearch.jsx",
        "path": "client/src/pages/RouteSearch.jsx",
        "type": "Component",
        "purpose": "Поиск маршрутов для пользователей",
        "route": "/search-route",
        "features": [
          "Выбор городов из dropdown",
          "Поиск маршрутов",
          "Google Maps визуализация",
          "Автоматические остановки",
          "Информация о расстоянии и времени"
        ],
        "imports": [
          "react",
          "KAZAKHSTAN_CITIES from constants/cities",
          "routesService from services/routesService",
          "routePlanner.css"
        ]
      },
      {
        "name": "AdminRoutes.jsx",
        "path": "client/src/pages/AdminRoutes.jsx",
        "type": "Component",
        "purpose": "Админ панель для управления маршрутами",
        "route": "/admin/routes",
        "access": "Только администраторы",
        "features": [
          "Добавление маршрутов",
          "Редактирование маршрутов",
          "Удаление маршрутов",
          "Таблица всех маршрутов",
          "Модальное окно для редактирования",
          "Автозаполнение расстояния"
        ],
        "imports": [
          "react",
          "KAZAKHSTAN_CITIES, getDistance, getDuration from constants/cities",
          "routesService from services/routesService",
          "adminRoutes.css"
        ]
      }
    ],
    "services": [
      {
        "name": "routesService.js",
        "path": "client/src/services/routesService.js",
        "type": "Service",
        "methods": {
          "getRoutes()": "Получить все маршруты из localStorage",
          "getRouteById(id)": "Получить маршрут по ID",
          "searchRoute(from, to)": "Поиск существующего маршрута",
          "findRoute(from, to)": "Найти или автогенерировать маршрут",
          "addRoute(data)": "Добавить новый маршрут",
          "updateRoute(id, data)": "Обновить маршрут",
          "deleteRoute(id)": "Удалить маршрут",
          "clearAll()": "Очистить все маршруты"
        },
        "storage": "localStorage (роман: 'routes_database')"
      }
    ],
    "constants": [
      {
        "name": "cities.js",
        "path": "client/src/constants/cities.js",
        "type": "Constants",
        "contains": [
          "KAZAKHSTAN_CITIES - массив 15 городов",
          "CITY_COORDINATES - координаты для Google Maps",
          "ROUTE_DISTANCES - расстояния между городами",
          "getDistance(from, to) - функция расчета расстояния",
          "getDuration(distanceKm) - функция расчета времени"
        ]
      }
    ],
    "styles": [
      {
        "name": "routePlanner.css",
        "path": "client/src/styles/routePlanner.css",
        "purpose": "Стили для RouteSearch компонента",
        "features": ["Адаптивный дизайн", "Темные градиенты", "Анимации"]
      },
      {
        "name": "adminRoutes.css",
        "path": "client/src/styles/adminRoutes.css",
        "purpose": "Стили для AdminRoutes компонента",
        "features": [
          "Таблица стили",
          "Модальное окно",
          "Форма элементы",
          "Адаптивность"
        ]
      }
    ],
    "cities": [
      "Астана",
      "Алматы",
      "Шымкент",
      "Караганда",
      "Актобе",
      "Тараз",
      "Павлодар",
